{
  "BackendSettings": {
    "Url": "http://localhost:5263",
    "ApiTimeoutSeconds": 30
  },
  "OcrSettings": {
    "DefaultIntervalSeconds": 5,
    "IdleSeconds": 2,
    "Areas": []
  },
  "WebSettings": {
    "EnableNotification": true,
    "SidebarWidth": 320,
