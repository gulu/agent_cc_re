{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5100"
      }
    }
  },

  "Database": {
    "Type": "SQLite",
    "ConnectionString": "Data Source=Data/qc.db"
  },

  "QC": {
    "PassScore": 90,
    "EnableLevel1": true,
    "EnableLevel2": true,
    "EnableLevel3": true,
    "EnableLevel4": true,
    "TinyBertModelPath": "models/tinybert_clinical.onnx",
    "DbPath": "Data/qc.db"
  }
}
